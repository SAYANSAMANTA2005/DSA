int arr[]={2,1,5,6,2,3};
int n=6;


int min_(int a,int b){

if(b>a){return a;}

else{return b;}}

int max_(int a,int b){

if(b<a){return a;}

else{return b;}}

int minheightfunction(int i,int j){
int height=arr[i];
for(int k=i;k<=j;k++){

height=min_(arr[k],height);}

return height;}

int base(int i,int j){
return j-i+1;

}

int area(int i,int j){

return minheightfunction(i,j)*base(i,j);
}

int solutionarea(){
int maxarea=0;
for(int i=0;i<n;i++){
for(int j=i;j<n;j++){

maxarea=max_(maxarea,area(i,j));
}}

return maxarea;
}

