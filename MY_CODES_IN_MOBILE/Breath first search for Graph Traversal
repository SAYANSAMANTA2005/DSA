struct queue{

int size;
int f;
int r;
int*arr;

};
int isfull(struct queue *s){
if(s->r==s->size-1){return 1;
    }
  else{return 0;}
}

int isempty (struct queue *s){
if(s->f==s->r){return 1;//it is true that queue is empty
}
  else{return 0;}//it is false that  queue is empty
  }

void  enqueue(struct queue *s,int data){
if(isfull(s)==1){
printf("queue is overflowed/ stack is full");
return ;}

else{
s->r++;
s->arr[s->r]=data;
return ;
   }
}

int  dequeue(struct queue*s){
if(isempty(s)==1){
printf("queue is underflow/stack is empty");
  return -100;}

else{
   s->f++;
   printf("\n dequeued element is: %d",s->arr[s->f]);
  
   return s->arr[s->f];
   }
}

