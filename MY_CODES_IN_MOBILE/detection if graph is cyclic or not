#include <stdio.h>
#include <stdlib.h>
#include<time.h>
#define MAX 100

int parent[MAX];
int rank[MAX];

// Function to initialize the parent and rank of each element
void make_set(int v) {
    parent[v] = v;
    rank[v] = 0;
}

// Function to find the root of the set containing v with path compression
int find_set(int v) {
    if (v != parent[v]) {
        parent[v] = find_set(parent[v]);
    }
    return parent[v];
}

// Function to unite two sets containing a and b using rank
void union_sets(int a, int b) {
    a = find_set(a);
    b = find_set(b);

    if (a != b) {
        if (rank[a] < rank[b]) {
            parent[a] = b;
        } else if (rank[a] > rank[b]) {
            parent[b] = a;
        } else {
            parent[b] = a;
            rank[a]++;
        }
    }
}

// Function to check if a graph is cyclic using union-find
int is_cyclic(int edges[][2], int num_edges, int num_vertices) {
    // Initialize the disjoint set
    for (int i = 0; i < num_vertices; i++) {
        make_set(i);
    }
    // Iterate through all edges
    for (int i = 0; i < num_edges; i++) {
        int u = edges[i][0];
        int v = edges[i][1];

        // Check if the current edge creates a cycle
        if (find_set(u) == find_set(v)) {
            return 1;  // Cycle detected
        }
        union_sets(u, v);//create edge between u and v
    }

    return 0;  // No cycle detected
}

int main() {

     clock_t start_time=clock();
    int num_vertices = 5;
    int num_edges = 5;

    // Define the edges of the graph
    int edges[][2] = {
        {0, 1},
        {1, 2},
        {2, 3},
        {3, 4},
        {4, 5}
    };

    if (is_cyclic(edges, num_edges, num_vertices)) {
        printf("Graph contains a cycle\n");
    } else {
        printf("Graph does not contain a cycle\n");
    }
    clock_t end_time=clock();
    double time_to_run_code=((double )(end_time-start_time))/
    CLOCKS_PER_SEC*1000000;

printf("time to run the code\n:%lf microsecond",time_to_run_code);
    return 0;
}

