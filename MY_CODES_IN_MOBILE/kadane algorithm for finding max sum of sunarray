#include<stdio.h>
#include<stdlib.h>
#include<time.h>
#define no_of_element 100
int arr[no_of_element];

int sum=0;

int main(){

clock_t start_time=clock();
int max=-100000;
int arr[]={5,-8,-1,4,0,8,5,-10,15};

int n=sizeof(arr)/sizeof(arr[0]);

int windowsize=3;
int k=windowsize;

//int sum=0;

max=0;

for(int k=0;k<windowsize;k++){sum=sum+arr[k];}
max=sum;
printf("arr[%d]=%d ,",0,arr[0]);
printf("sum[%d]=%d ,",0,sum);
printf("max[%d]=%d ,\n\n",0,max);

for(int j=1;j+k<=n;j++){

printf("arr[%d]=%d ,",j,arr[j]);
sum=sum+arr[j+k-1]-arr[j-1];

printf("%d ",sum);

printf("sum[%d]=%d ,",j,sum);
if(max<sum){max=sum;}
printf("max[%d]=%d ,\n\n",j,max);
  }
 

printf("\nmax[%d]\n(index of starting array element of summing) of subarray is:%d",0,max);

clock_t end_time=clock();

double timespend=((double)(end_time-start_time))/
CLOCKS_PER_SEC*1000000;
printf("\nTime spend to run the code\n:%lf microsecond",timespend);
return 0;

}
