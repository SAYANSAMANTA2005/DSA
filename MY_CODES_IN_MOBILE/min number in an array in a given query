int node(int l,int h){

if(l==h){

return val[l][h];}//base case for leaf node

else{
node(l,(l+h)/2);//recursive call for next children exploration
node(((l+h)/2)+1,h);

val[l][h]= min(val[l][(l+h)/2],val[((l+h)/2)+1][h]);// storing the nodes value (otherthan leaf nodes) from children nodes information
printf("%d, %d node val is:%d\n",l,h,val[l][h]);
return val[l][h];

 
  }

}

